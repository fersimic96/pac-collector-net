{
  "name": "lims-ethernet-txt",
  "filenameTemplate": "{Serial}_{SampleIdentifier}_{StartAt:yyyyMMdd_HHmm}.txt",
  "encoding": "utf-8",
  "lineEnding": "CRLF",
  "lines": [
    "Status: C",
    "Instrument: {Alias|AnalyzerType}",
    "Probe serial number: {Serial}",
    "",
    "Sample: {SampleIdentifier}",
    "Description: ",
    "Start of distillation: {StartAt:yyyy-MM-ddTHH:mm:ss.000|NaN}",
    "End of distillation: {EndAt:yyyy-MM-ddTHH:mm:ss.000|NaN}",
    "Standard: {Program|NaN}",
    "Group: {Extra.Group|Extra.group|1}",
    "Temp. unit: C",
    "Product: {Extra.Product|Extra.product|}",
    "",
    "Percent recovery: {Recovery:R|NaN}",
    "Corr. recovery: NaN",
    "Residue: {Residue:R|NaN}",
    "Barom. pressure: {Extra.BaromPressure|Extra.barom_pressure|NaN}",
    "Total recovery: NaN",
    "Corr. total recovery: NaN",
    "Observed loss: NaN",
    "Corr. loss: NaN",
    "Condenser temp.: {Extra.CondensorTemp|NaN}",
    "Receiver temp.: {Extra.ReceiverTemp|NaN}",
    "Ambient temp.: NaN",
    "",
    "User(Instrument): {Operator|}",
    "Heating mode: NaN",
    "FBP detection mode: NaN",
    "Final heating adjustment: NaN",
    "Stop condition: NaN",
    "Temp. stop: NaN",
    "",
    "Corrected",
    "========= ",
    "IBP {Ibp:R|NaN}",
    "{Curve.ForEach:{PctLabel} {TemperatureC:R}}",
    "FBP {Fbp:R|NaN}",
    ""
  ]
}
